{
  "name": "photo-diary-server",
  "version": "0.5.1",
  "description": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "NODE_ENV=dev tsx index.ts",
    "prod": "NODE_ENV=prod pm2 start --interpreter tsx index.ts",
    "dev": "NODE_ENV=dev tsx watch index.ts",
    "test": "DB_DRIVER=dummy NODE_ENV=test vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build:ui": "cd ../react-app && npm run build --prod && rm -rf ../server/build && cp -r build ../server/"
  },
  "author": "Ville Misaki",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jose": "^5.10.0",
    "morgan": "^1.10.1",
    "uuid": "^11.1.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "@types/yargs": "^17.0.35",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "github:vlumi/photo-diary"
  }
}
